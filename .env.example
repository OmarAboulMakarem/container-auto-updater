# ── Required ──────────────────────────────────────────────────────────────────

# Comma-separated list of full image refs to watch
# Example: ghcr.io/youruser/my-app:latest,nginx:stable
WATCH_IMAGES=

# Path to docker-compose.yml INSIDE the watcher container (matches your volume mount)
COMPOSE_FILE=/compose/docker-compose.yml

# Human-readable project name used in email subjects.
# Default: parent directory of COMPOSE_FILE (often "compose" — set this explicitly).
CA_UPDATER_PROJECT_NAME=my-app

# How often to check for updates (in minutes). Default: 5
CHECK_INTERVAL_MINUTES=5

# Set to "true" to skip the first redeploy on watcher startup.
# Prevents an unnecessary redeploy every time the watcher container restarts.
SKIP_FIRST_RUN=true

# ── Notifications ─────────────────────────────────────────────────────────────

# Who to notify (shared by both providers)
EMAIL_FROM=alerts@yourdomain.com
# Comma-separated list of recipients
EMAIL_TO=ops@yourdomain.com,oncall@yourdomain.com

# Notification provider: "sendgrid" (default) or "smtp"
NOTIFY_PROVIDER=sendgrid

# ── SendGrid (NOTIFY_PROVIDER=sendgrid) ───────────────────────────────────────

SENDGRID_API_KEY=

# ── SMTP (NOTIFY_PROVIDER=smtp) ───────────────────────────────────────────────

SMTP_HOST=smtp.yourdomain.com
# 587 = STARTTLS (default), 465 = implicit TLS (smtps), 25 = plain
SMTP_PORT=587
# Leave blank for unauthenticated relay
SMTP_USERNAME=
SMTP_PASSWORD=

# ── AWS ECR (only needed if watching ECR images) ──────────────────────────────

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Oracle OCIR (only needed if watching OCIR images) ─────────────────────────

# Format: <tenancy-namespace>/<username>
# e.g.  mytenancy/oracleidentitycloudservice/user@example.com
OCIR_USERNAME=
OCIR_AUTH_TOKEN=

# ── Docker Hub (only needed if watching private Docker Hub images) ─────────────

DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=
